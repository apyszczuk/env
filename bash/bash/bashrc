alias ls='ls --color=auto'
alias ll='ls -l'
alias gst='git status'

color_white="01;37"
color_yellow="01;33"
color_blue="01;34"
color_red="01;31"
color_green="01;32"

function print_in_color()
{
    color="$1"
    str="$2"
    printf "\[\033[%sm\]%s\[\033[0m\]" "$color" "$str"
}

function prompt_git_untracked()
{
    stat="$1"
    value=$(printf "$stat" | grep "^Untracked files:")
    
    if [ "$value" == "" ]; then
        printf ""
    else
        print_in_color "$color_blue" "%"
    fi
}

function prompt_git_modified()
{
    stat="$1"
    value=$(printf "$stat" | grep "^Changes not staged for commit:")
    
    if [ "$value" == "" ]; then
        printf ""
    else
        print_in_color "$color_red" "*"
    fi
}

function prompt_git_staged()
{
    stat="$1"
    value=$(printf "$stat" | grep "^Changes to be committed:")

    if [ "$value" == "" ]; then
        printf ""
    else
        print_in_color "$color_green" "+"
    fi
}
