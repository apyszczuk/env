alias ls='ls --color=auto'
alias ll='ls -l'

function prompt_git_untracked()
{
    value=$(git status | grep "Untracked files:")
    
    if [ "$value" == "" ]; then
        printf ""
    else
        printf "\[\033[01;34m\]%s\[\033[0m\]" "%"
    fi
}

function prompt_git_modified()
{
    value=$(git diff-index HEAD)

    if [ "$value" == "" ]; then
        printf ""
    else
        printf "\[\033[01;31m\]*\[\033[0m\]"
    fi
}

function prompt_git_staged()
{
    # printf "\[\033[01;32m\]+\[\033[0m\]"
    printf ""
}
