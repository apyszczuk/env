function prompt_git_branch_name()
{
    stat="$1"
    branch_name=$(printf "$stat" | grep "^On branch" | awk '{ print $3}')
    if [ "$branch_name" == "" ]; then
        branch_name=$(printf "$stat" | grep "^HEAD detached at" | awk '{ print $4}')
    fi
    print_in_color "$color_green" "$branch_name"
}

function prompt_git()
{
    # Probably add functions in_red(str); in_green(str) etc
    is_repo=$(git rev-parse --is-inside-work-tree 2> /dev/null)
    if [ "$is_repo" == "true" ]; then
        stat=$(git status)

        printf " "
        printf "("
        prompt_git_branch_name "$stat"
        prompt_git_modified "$stat"
        prompt_git_staged "$stat"
        prompt_git_untracked "$stat"
        printf ")"
    else
        printf ""
    fi
}

function prompt()
{
    print_in_color "$color_white" "\u"
    printf "@"
    print_in_color "$color_yellow" "\h"
    printf ":"
    print_in_color "$color_blue" "\w"
    prompt_git
    printf " $ "
}

export PROMPT_COMMAND="export PS1=\$(prompt)"
